# .gitignore for dotnet projects
# Ignore build output
bin/
obj/

# Ignore user-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Ignore VS Code settings
.vscode/

# Ignore logs
*.log

# Ignore releases
releases/

# Ignore temporary files
*.tmp
*.temp
~*

# Ignore OS-specific files
.DS_Store
Thumbs.db
